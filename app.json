{
  "expo": {
    "name": "NTS Radio",
    "slug": "nts",
    "version": "1.0.1",
    "orientation": "portrait",
    "scheme": "nts",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.vandam.nts",
      "permissions": [
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/PublicSans-Regular.ttf"
          ]
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme",
      "expo-asset",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e98d74da-0f9f-4ea5-9110-e1e5775c011a"
      }
    }
  }
}
