+/**
+ * Gets the native player snapshot used to synchronise now playing UI.
+ */
+export async function getNowPlayingSnapshot(): Promise<NowPlayingSnapshot> {
+  const snapshot = await TrackPlayer.getNowPlayingSnapshot();
+  return {
+    ...snapshot,
+    activeIndex: snapshot.activeIndex ?? undefined,
+    activeTrack: snapshot.activeTrack ?? undefined,
+    activeTrackId: snapshot.activeTrackId ?? undefined,
+  };
+}
+
+/**
+ * Gets the last snapshot captured before Android stopped playback.
+ */
+export async function getLastStoppedSnapshot(): Promise<
+  LastStoppedSnapshot | undefined
+> {
+  if (typeof TrackPlayer.getLastStoppedSnapshot !== 'function') {
+    return undefined;
+  }
+
+  const snapshot = await TrackPlayer.getLastStoppedSnapshot();
+  return snapshot
+    ? {
+        ...snapshot,
+        activeIndex: snapshot.activeIndex ?? undefined,
+        activeTrackId: snapshot.activeTrackId ?? undefined,
+      }
+    : undefined;
+}
